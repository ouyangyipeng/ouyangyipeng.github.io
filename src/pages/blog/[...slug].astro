---
import { getCollection } from "astro:content";
import { getSiteConfig } from "../../config";
import { ui } from "../../i18n/ui";
import BlogLayout from "../../layouts/BlogLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, lang: "en" },
  }));
}

const { post, lang } = Astro.props;
const siteConfig = getSiteConfig(lang);
const t = ui[lang];
const { Content } = await post.render();
const prefix = "/blog";

const categoryClass = `cat-${post.data.category.toLowerCase().replace(/\s+/g, "-")}`;
---

<BlogLayout lang={lang} title={post.data.title} activeNav="recent">
  <article>
    <!-- Article header -->
    <div class="article-header">
      {post.data.cover && (
        <div class="mb-6 rounded-lg overflow-hidden">
          <img src={post.data.cover} alt={post.data.title} class="w-full h-48 object-cover" />
        </div>
      )}
      <h1 class="article-title">{post.data.title}</h1>
      <div class="article-meta">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
        </time>
        {post.data.updatedDate && (
          <span>
            · Updated {post.data.updatedDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </span>
        )}
        <span class:list={[categoryClass, "post-card-category"]}>{post.data.category}</span>
      </div>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="article-tags">
          {post.data.tags.map((tag: string) => (
            <a href={`${prefix}/tags/${tag.toLowerCase()}`} class="tag-item">{tag}</a>
          ))}
        </div>
      )}
    </div>

    <!-- Article content -->
    <div class="prose" style={`--accent-color: ${siteConfig.personal.accentColor}`}>
      <Content />
    </div>

    <!-- Back link -->
    <div class="mt-16 pt-8 border-t border-gray-200">
      <a href={`${prefix}/`} class="article-back">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
        {t.blogBack}
      </a>
    </div>
  </article>
</BlogLayout>