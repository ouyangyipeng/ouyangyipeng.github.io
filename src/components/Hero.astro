---
import { getSiteConfig } from "../config";
import { ui } from "../i18n/ui";
import type { Lang } from "../config/types";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const siteConfig = getSiteConfig(lang);
const t = ui[lang];
---

<div
  id="hero"
  class="relative isolate overflow-hidden bg-white py-24 md:min-h-screen md:flex md:items-center"
  style={`--accent-color: ${siteConfig.personal.accentColor}`}
>
  <!-- Gradient overlay -->
  <div
    class="absolute inset-0 -z-10"
    style={`background: radial-gradient(ellipse 800px 1200px at 0% 0%, ${siteConfig.personal.accentColor}40 0%, ${siteConfig.personal.accentColor}25 20%, ${siteConfig.personal.accentColor}10 40%, rgba(255, 255, 255, 0.3) 70%, rgba(255, 255, 255, 0.8) 90%, white 100%)`}
  >
  </div>
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full stroke-gray-200 [mask-image:radial-gradient(100%_100%_at_top_right,white,transparent)]"
  >
    <defs>
      <pattern
        x="50%"
        y={-1}
        id="programming-symbols"
        width="400"
        height="400"
        patternUnits="userSpaceOnUse"
      >
        <text
          x="50"
          y="50"
          fill={siteConfig.personal.accentColor}
          font-family="monospace"
          font-size="24"
          transform="rotate(-15)"
        ></></text>
        <text
          x="150"
          y="100"
          fill={siteConfig.personal.accentColor}
          font-family="monospace"
          font-size="20"
          transform="rotate(10)"
        >{}</text>
        <text
          x="250"
          y="80"
          fill={siteConfig.personal.accentColor}
          font-family="monospace"
          font-size="18"
          transform="rotate(-5)"
        >=></text>
        <text
          x="100"
          y="200"
          fill={siteConfig.personal.accentColor}
          font-family="monospace"
          font-size="22"
          transform="rotate(15)"
        >[]</text>
        <text
          x="300"
          y="180"
          fill={siteConfig.personal.accentColor}
          font-family="monospace"
          font-size="20"
          transform="rotate(-10)"
        ><></text>
        <text
          x="200"
          y="250"
          fill={siteConfig.personal.accentColor}
          font-family="monospace"
          font-size="24"
          transform="rotate(5)"
        >()</text>
        <text
          x="50"
          y="320"
          fill={siteConfig.personal.accentColor}
          font-family="monospace"
          font-size="18"
          transform="rotate(-8)"
        >::</text>
        <text
          x="350"
          y="300"
          fill={siteConfig.personal.accentColor}
          font-family="monospace"
          font-size="22"
          transform="rotate(12)"
        >#</text>
      </pattern>
    </defs>
    <rect width="100%" height="100%" stroke-width="0" fill="url(#programming-symbols)" opacity="0.2" />
  </svg>

  <!-- Centered big text — matching devportfolio style -->
  <div class="h-full mx-auto p-8 sm:p-12 md:p-24 flex items-center">
    <div>
      <h2
        class="text-pretty text-xl sm:text-2xl md:text-5xl font-bold tracking-tight text-gray-700 animate-fade-in"
      >
        {t.heroGreeting}
      </h2>
      <h1
        class="mt-6 sm:mt-8 md:mt-10 text-pretty text-4xl sm:text-5xl md:text-6xl lg:text-8xl font-bold tracking-tight text-gray-800 animate-fade-in animation-delay-200"
      >
        {t.heroIm} <span style={{ color: siteConfig.personal.accentColor }}>{siteConfig.personal.name}</span>
      </h1>
      <p
        class="mt-4 sm:mt-6 md:mt-8 text-pretty text-base sm:text-lg md:text-xl/8 font-medium text-gray-600 animate-fade-in animation-delay-400"
      >
        {siteConfig.personal.title}
      </p>
    </div>
  </div>

  <!-- Social links at bottom — matching devportfolio style -->
  <div
    class="absolute bottom-0 left-0 right-0 p-8 sm:p-12 md:p-24 flex gap-x-4 sm:gap-x-6 md:gap-x-8 text-gray-700 animate-fade-in animation-delay-600"
  >
    <a
      href={`mailto:${siteConfig.personal.social.email}`}
      aria-label="Email"
      class="transition-colors duration-300 hover:text-[var(--accent-color)]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8">
        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
        <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"></path>
        <path d="M3 7l9 6l9 -6"></path>
      </svg>
    </a>
    {siteConfig.personal.social.github && (
      <a
        href={siteConfig.personal.social.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="transition-colors duration-300 hover:text-[var(--accent-color)]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.928-.399 2.929-.399 1.001 0 2.007.134 2.929.399 3.293-1.552 3.301-1.23 3.301-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-3.807 5.624-5.479 5.919.43.372.823 1.102.823 2.222v3.293c0 .719.481 1.278 1.229 1.078 4.771-1.586 8.207-5.086 8.207-11.388 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    )}
    {siteConfig.personal.social.orcid && (
      <a
        href={siteConfig.personal.social.orcid}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="ORCID"
        class="transition-colors duration-300 hover:text-[var(--accent-color)]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8">
          <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.411c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.736 3.861h1.473v10.159H6.633V8.272zm3.947 0h3.947c3.736 0 5.473 2.625 5.473 5.078 0 2.625-1.847 5.078-5.473 5.078h-3.947V8.272zm1.473 1.578v7.922h2.474c2.105 0 3.473-1.578 3.473-3.947 0-2.263-1.368-3.947-3.473-3.947h-2.474z"/>
        </svg>
      </a>
    )}
    {siteConfig.personal.social.website && (
      <a
        href={siteConfig.personal.social.website}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Website"
        class="transition-colors duration-300 hover:text-[var(--accent-color)]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 sm:h-7 sm:w-7 md:h-8 md:w-8">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0"></path>
          <path d="M3.6 9h16.8"></path>
          <path d="M3.6 15h16.8"></path>
          <path d="M12 3a15 15 0 0 0 4 9a15 15 0 0 1 -4 9a15 15 0 0 1 -4 -9a15 15 0 0 0 4 -9"></path>
        </svg>
      </a>
    )}
  </div>
</div>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.8s ease-out both;
  }
  .animation-delay-200 {
    animation-delay: 0.2s;
  }
  .animation-delay-400 {
    animation-delay: 0.4s;
  }
  .animation-delay-600 {
    animation-delay: 0.6s;
  }
</style>