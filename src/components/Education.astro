---
import { getSiteConfig } from "../config";
import { ui } from "../i18n/ui";
import type { Lang } from "../config/types";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const siteConfig = getSiteConfig(lang);
const t = ui[lang];
---

<section id="education" class="py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 mb-12">
      {t.sectionEducation}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {siteConfig.education.map((edu) => (
        <div class="p-6 rounded-xl border border-gray-200 bg-white">
          <div class="flex items-start justify-between gap-2 mb-2">
            <h3 class="text-lg font-bold text-gray-900">
              {edu.link ? (
                <a href={edu.link} target="_blank" rel="noopener noreferrer" class="hover:underline" style={`color: ${siteConfig.personal.accentColor}`}>
                  {edu.school}
                </a>
              ) : (
                edu.school
              )}
            </h3>
            <span class="text-sm text-gray-500">{edu.dateRange}</span>
          </div>
          <p class="text-base font-medium text-gray-700 mb-3">{edu.degree}</p>
          {edu.achievements.length > 0 && (
            <ul class="space-y-1">
              {edu.achievements.map((achievement) => (
                <li class="text-sm text-gray-600">• {achievement}</li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>
  </div>
</section>