---
import { getSiteConfig } from "../config";
import { ui } from "../i18n/ui";
import type { Lang } from "../config/types";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const siteConfig = getSiteConfig(lang);
const t = ui[lang];
---

<section id="experience" class="py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 mb-12">
      {t.sectionExperience}
    </h2>
    <div class="space-y-8">
      {siteConfig.experience.map((exp, idx) => (
        <div class="relative pl-8 border-l-2 border-gray-200 pb-8 last:pb-0">
          <!-- Timeline dot -->
          <div
            class="absolute -left-[9px] top-0 w-4 h-4 rounded-full border-2"
            style={`border-color: ${siteConfig.personal.accentColor}; background-color: white`}
          ></div>

          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-2">
            <h3 class="text-lg sm:text-xl font-bold text-gray-900">
              {exp.link ? (
                <a href={exp.link} target="_blank" rel="noopener noreferrer" class="hover:underline" style={`color: ${siteConfig.personal.accentColor}`}>
                  {exp.organization}
                </a>
              ) : (
                exp.organization
              )}
            </h3>
            <span class="text-sm text-gray-500">{exp.dateRange}</span>
          </div>
          <p class="text-base font-medium text-gray-700 mb-3">{exp.title}</p>
          <ul class="space-y-2">
            {exp.bullets.map((bullet) => (
              <li class="text-sm text-gray-600 leading-6">
                • {bullet}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>