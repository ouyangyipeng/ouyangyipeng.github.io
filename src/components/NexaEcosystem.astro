---
import { siteConfig } from "../config";
const hasNexa = siteConfig.nexa && siteConfig.nexa.links && siteConfig.nexa.links.length > 0;
---

{
  hasNexa && (
    <section id="nexa" class="relative overflow-hidden py-16 sm:py-20 md:py-24 lg:py-32" style={`background-color: ${siteConfig.personal.accentColor}10`}>
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              Nexa
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.personal.accentColor}`}
            />
            <p class="mt-6 text-base sm:text-lg text-gray-600 leading-relaxed">
              {siteConfig.nexa.intro}
            </p>
            <div class="mt-6 flex flex-wrap gap-3">
              {siteConfig.nexa.github && (
                <a
                  href={siteConfig.nexa.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-4 sm:px-5 py-2 sm:py-2.5 rounded-lg text-sm sm:text-base font-medium text-white transition-all duration-300 hover:opacity-90"
                  style={`background-color: ${siteConfig.personal.accentColor}`}
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                  </svg>
                  Star on GitHub
                </a>
              )}
              {siteConfig.nexa.paper && (
                <a
                  href={siteConfig.nexa.paper}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-4 sm:px-5 py-2 sm:py-2.5 rounded-lg text-sm sm:text-base font-medium border-2 transition-all duration-300 hover:bg-gray-100"
                  style={`border-color: ${siteConfig.personal.accentColor}; color: ${siteConfig.personal.accentColor}`}
                >
                  📄 Read Paper
                </a>
              )}
              {siteConfig.nexa.docs && (
                <a
                  href={siteConfig.nexa.docs}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-4 sm:px-5 py-2 sm:py-2.5 rounded-lg text-sm sm:text-base font-medium text-gray-700 bg-gray-100 transition-all duration-300 hover:bg-gray-200"
                >
                  📚 Documentation
                </a>
              )}
            </div>
          </div>

          <div class="lg:col-span-8">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
              {siteConfig.nexa.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block p-4 sm:p-5 md:p-6 bg-white rounded-xl border border-gray-200 transition-all duration-300 hover:shadow-xl hover:border-gray-300 hover:-translate-y-1"
                >
                  <div class="text-2xl sm:text-3xl mb-3">
                    {link.icon || "🔗"}
                  </div>
                  <h3 class="text-lg sm:text-xl font-bold text-gray-900 mb-2">
                    {link.name}
                  </h3>
                  <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
                    {link.description}
                  </p>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}