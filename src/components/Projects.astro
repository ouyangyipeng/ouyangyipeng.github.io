---
import { getSiteConfig } from "../config";
import { ui } from "../i18n/ui";
import type { Lang } from "../config/types";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const siteConfig = getSiteConfig(lang);
const t = ui[lang];
---

<section id="projects" class="py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 mb-12">
      {t.sectionProjects}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {siteConfig.projects.map((project) => (
        <div
          class="p-6 rounded-xl border border-gray-200 bg-white transition-all duration-300 hover:shadow-lg hover:border-gray-300"
        >
          <div class="flex items-start justify-between gap-2 mb-3">
            <h3 class="text-lg font-bold text-gray-900">
              {project.link ? (
                <a href={project.link} target="_blank" rel="noopener noreferrer" class="hover:underline">
                  {project.name}
                </a>
              ) : (
                project.name
              )}
            </h3>
            {project.link && (
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-400 hover:text-gray-600 transition-colors"
                style={`hover:color: ${siteConfig.personal.accentColor}`}
              >
                →
              </a>
            )}
          </div>
          <p class="text-sm text-gray-600 mb-4 leading-6">
            {project.description}
          </p>
          {(project.role || project.level) && (
            <div class="flex flex-wrap gap-2 mb-3">
              {project.role && (
                <span class="px-2 py-1 rounded text-xs font-medium" style={`background-color: ${siteConfig.personal.accentColor}20; color: ${siteConfig.personal.accentColor}`}>
                  {project.role}
                </span>
              )}
              {project.level && (
                <span class="px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-700">
                  {project.level}
                </span>
              )}
            </div>
          )}
          <div class="flex flex-wrap gap-1.5">
            {project.skills.map((skill) => (
              <span class="px-2 py-0.5 rounded text-xs font-medium bg-gray-50 text-gray-600 border border-gray-100">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>