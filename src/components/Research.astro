---
import { getSiteConfig } from "../config";
import { ui } from "../i18n/ui";
import type { Lang } from "../config/types";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const siteConfig = getSiteConfig(lang);
const t = ui[lang];

const pinnedPapers = siteConfig.research.filter((p) => p.pinned);
const otherPapers = siteConfig.research.filter((p) => !p.pinned);
---

<section id="research" class="py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 mb-12">
      {t.sectionResearch}
    </h2>

    <!-- Pinned papers -->
    {pinnedPapers.length > 0 && (
      <div class="mb-12">
        <div class="space-y-8">
          {pinnedPapers.map((paper) => (
            <div
              class="p-6 sm:p-8 rounded-xl border-2 bg-white"
              style={`border-color: ${siteConfig.personal.accentColor}`}
            >
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                <h3 class="text-lg sm:text-xl font-bold text-gray-900">
                  {paper.title}
                </h3>
                <div class="flex flex-wrap gap-2">
                  {paper.status && (
                    <span
                      class={`px-3 py-1 rounded-full text-xs font-bold ${
                        paper.status === "accepted"
                          ? "bg-green-100 text-green-800"
                          : paper.status === "submitting"
                          ? "bg-yellow-100 text-yellow-800"
                          : "bg-purple-100 text-purple-800"
                      }`}
                    >
                      {paper.status === "accepted"
                        ? t.statusAccepted
                        : paper.status === "submitting"
                        ? t.statusSubmitting
                        : t.statusPreprint}
                    </span>
                  )}
                  {paper.level && (
                    <span class="px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
                      {paper.level}
                    </span>
                  )}
                </div>
              </div>
              <p class="text-sm text-gray-500 mb-2">
                {paper.venue}
              </p>
              <p class="text-sm text-gray-600 mb-3">
                {paper.authors}
              </p>
              {paper.myRole && (
                <p class="text-sm font-medium mb-2" style={`color: ${siteConfig.personal.accentColor}`}>
                  {paper.myRole}
                </p>
              )}
              {paper.creditRoles && paper.creditRoles.length > 0 && (
                <p class="text-sm text-gray-500 mb-2">
                  <span class="font-medium">{t.creditLabel}:</span> {paper.creditRoles.join(", ")}
                </p>
              )}
              {paper.dois && paper.dois.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-2">
                  {paper.dois.map((doi) => (
                    <a
                      href={`https://doi.org/${doi}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs px-2 py-1 rounded bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors"
                    >
                      {t.doiLabel}: {doi}
                    </a>
                  ))}
                </div>
              )}
              {paper.link && (
                <a
                  href={paper.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center mt-3 text-sm font-medium transition-colors"
                  style={`color: ${siteConfig.personal.accentColor}`}
                >
                  Link →
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Other papers -->
    {otherPapers.length > 0 && (
      <div class="space-y-6">
        {otherPapers.map((paper) => (
          <div class="p-5 sm:p-6 rounded-xl border border-gray-200 bg-white">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
              <h3 class="text-base sm:text-lg font-bold text-gray-900">
                {paper.title}
              </h3>
              <div class="flex flex-wrap gap-2">
                {paper.status && (
                  <span
                    class={`px-2 py-1 rounded-full text-xs font-bold ${
                      paper.status === "accepted"
                        ? "bg-green-100 text-green-800"
                        : paper.status === "submitting"
                        ? "bg-yellow-100 text-yellow-800"
                        : "bg-purple-100 text-purple-800"
                    }`}
                  >
                    {paper.status === "accepted"
                      ? t.statusAccepted
                      : paper.status === "submitting"
                      ? t.statusSubmitting
                      : t.statusPreprint}
                  </span>
                )}
                {paper.level && (
                  <span class="px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
                    {paper.level}
                  </span>
                )}
              </div>
            </div>
            <p class="text-sm text-gray-500 mb-1">
              {paper.venue}
            </p>
            <p class="text-sm text-gray-600 mb-2">
              {paper.authors}
            </p>
            {paper.myRole && (
              <p class="text-sm font-medium" style={`color: ${siteConfig.personal.accentColor}`}>
                {paper.myRole}
              </p>
            )}
            {paper.contribution && (
              <p class="text-sm text-gray-500 mt-1">
                {paper.contribution}
              </p>
            )}
            {paper.link && (
              <a
                href={paper.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center mt-2 text-sm font-medium transition-colors"
                style={`color: ${siteConfig.personal.accentColor}`}
              >
                Link →
              </a>
            )}
          </div>
        ))}
      </div>
    )}
  </div>
</section>