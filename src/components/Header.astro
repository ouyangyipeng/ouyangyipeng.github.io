---
import { ui } from "../i18n/ui";
import type { Lang } from "../config/types";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];
const altLang: Lang = lang === "en" ? "zh" : "en";
const altPath = altLang === "en" ? "/" : "/zh/";
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 hidden md:block transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-8 py-4">
    <ul class="flex items-center gap-8 justify-center">
      <li>
        <a
          href="#about"
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          {t.navAbout}
        </a>
      </li>
      <li>
        <a
          href="#nexa"
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          {t.navNexa}
        </a>
      </li>
      <li>
        <a
          href="#research"
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          {t.navResearch}
        </a>
      </li>
      <li>
        <a
          href="#experience"
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          {t.navExperience}
        </a>
      </li>
      <li>
        <a
          href="#projects"
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          {t.navProjects}
        </a>
      </li>
      <li>
        <a
          href="#education"
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          {t.navEducation}
        </a>
      </li>
      <li>
        <a
          href="#awards"
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          {t.navAwards}
        </a>
      </li>
      <li>
        <a
          href={lang === "en" ? "/blog/" : "/zh/blog/"}
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          {t.navBlog}
        </a>
      </li>
      <li class="ml-4 flex items-center gap-3">
        <ThemeToggle size="md" />
        <a
          href={altPath}
          class="px-3 py-1 rounded-full text-sm font-bold border-2 transition-colors duration-300"
          style={`border-color: var(--accent-color, #6d28d9); color: var(--accent-color, #6d28d9);`}
        >
          {t.langSwitchLabel}
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const header = document.getElementById("header");
  if (header) {
    window.addEventListener("scroll", () => {
      if (window.scrollY > 50) {
        header.classList.add("backdrop-blur-md", "shadow-sm");
        header.style.backgroundColor = "var(--header-bg, rgba(255, 255, 255, 0.8))";
        header.classList.remove("bg-transparent");
      } else {
        header.classList.remove("backdrop-blur-md", "shadow-sm");
        header.style.backgroundColor = "transparent";
        header.classList.add("bg-transparent");
      }
    });
  }
</script>