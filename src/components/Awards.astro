---
import { getSiteConfig } from "../config";
import { ui } from "../i18n/ui";
import type { Lang } from "../config/types";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const siteConfig = getSiteConfig(lang);
const t = ui[lang];
---

<section id="awards" class="py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 mb-12">
      {t.sectionAwards}
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {siteConfig.awards.map((award) => (
        <div
          class="p-4 rounded-xl border border-gray-200 bg-white transition-all duration-300 hover:shadow-md"
        >
          <h3 class="text-base font-bold text-gray-900 mb-1">
            {award.link ? (
              <a href={award.link} target="_blank" rel="noopener noreferrer" class="hover:underline">
                {award.title}
              </a>
            ) : (
              award.title
            )}
          </h3>
          {award.date && (
            <p class="text-xs text-gray-500 mb-1">{award.date}</p>
          )}
          {award.description && (
            <p class="text-sm text-gray-600">{award.description}</p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>