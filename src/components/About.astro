---
import { getSiteConfig } from "../config";
import { ui } from "../i18n/ui";
import type { Lang } from "../config/types";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const siteConfig = getSiteConfig(lang);
const t = ui[lang];
---

<section id="about" class="py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 mb-12">
      {t.sectionAbout}
    </h2>
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 lg:gap-12">
      <div class="lg:col-span-1">
        <p class="text-base sm:text-lg leading-7 text-gray-600">
          {siteConfig.about.bio}
        </p>
      </div>
      <div class="lg:col-span-3">
        <div class="flex flex-wrap gap-2 mb-8">
          {siteConfig.about.skills.map((skill) => (
            <span
              class="px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-700 border border-gray-200"
            >
              {skill}
            </span>
          ))}
        </div>
        <div class="flex flex-wrap gap-3">
          {siteConfig.about.researchDirections.map((dir) => (
            <span
              class="px-4 py-2 rounded-full text-sm sm:text-base font-medium text-white"
              style={`background-color: ${siteConfig.personal.accentColor}`}
            >
              {dir}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>